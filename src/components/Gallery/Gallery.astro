---
// Utils
import { Picture } from "astro:assets";

// Images
import foto22 from "@assets/images/Morelia/Galería/foto-22.jpeg";
import foto26 from "@assets/images/Morelia/Galería/foto-26.jpeg";
import foto36 from "@assets/images/Morelia/Momentos/foto-36.jpeg";
import foto23 from "@assets/images/Morelia/Galería/foto-23.jpeg";
import foto35 from "@assets/images/Morelia/Momentos/foto-35.jpeg";
import foto27 from "@assets/images/Morelia/Galería/foto-27.jpeg";
import foto34 from "@assets/images/Morelia/Momentos/foto-34.jpeg";
import foto28 from "@assets/images/Morelia/Galería/foto-28.jpeg";
import foto37 from "@assets/images/Morelia/Momentos/foto-37.jpeg";
---

<section id="gallery">
  <div class="cs-container">
    <span class="cs-topper">Momentos especiales</span>
    <h2 class="cs-title">
      Una galería de recuerdos para Morelia
    </h2>
    <div class="cs-image-group">
      <!-- Row 1-->
      <div class="cs-row cs-row-1">
        <Picture
          src={foto22}
          alt="Recuerdo especial de Morelia"
          width={400}
          height={560}
          formats={['avif', 'webp']}
          pictureAttributes={{ class: "cs-picture cs-picture1" }}
        />
        <Picture
          src={foto23}
          alt="Momento especial de Morelia"
          width={400}
          height={560}
          formats={['avif', 'webp']}
          pictureAttributes={{ class: "cs-picture cs-picture2" }}
        />
        <Picture
          src={foto34}
          alt="Un recuerdo para siempre"
          width={400}
          height={560}
          formats={['avif', 'webp']}
          pictureAttributes={{ class: "cs-picture cs-picture3" }}
        />
      </div>
      <!-- Row 2 -->
      <div class="cs-row cs-row-2">
        <Picture
          src={foto26}
          alt="Fotografía de recuerdo"
          width={400}
          height={560}
          formats={['avif', 'webp']}
          pictureAttributes={{ class: "cs-picture cs-picture1" }}
        />
        <Picture
          src={foto35}
          alt="Momento inolvidable de Morelia"
          width={400}
          height={560}
          formats={['avif', 'webp']}
          pictureAttributes={{ class: "cs-picture cs-picture2" }}
        />
        <Picture
          src={foto27}
          alt="Recuerdo con cariño"
          width={400}
          height={560}
          formats={['avif', 'webp']}
          pictureAttributes={{ class: "cs-picture cs-picture3" }}
        />
      </div>
      <!-- Row 3 -->
      <div class="cs-row cs-row-3">
        <Picture
          src={foto36}
          alt="Memoria especial de Morelia"
          width={400}
          height={560}
          formats={['avif', 'webp']}
          pictureAttributes={{ class: "cs-picture cs-picture1" }}
        />
        <Picture
          src={foto28}
          alt="Instante para recordar"
          width={400}
          height={560}
          formats={['avif', 'webp']}
          pictureAttributes={{ class: "cs-picture cs-picture2" }}
        />
        <Picture
          src={foto37}
          alt="Foto del cumpleaños de Morelia"
          width={400}
          height={560}
          formats={['avif', 'webp']}
          pictureAttributes={{ class: "cs-picture cs-picture3" }}
        />
      </div>
    </div>
  </div>
</section>

<style lang="less">
  /*-- -------------------------- -->
<---          Gallery           -->
<--- -------------------------- -*/

  /* Mobile - 360px - Contains hover animation */
  @media only screen and (min-width: 0em) {
    #gallery {
      /* Centers button */
      text-align: center;
      padding: var(--sectionPadding);
      position: relative;
      /* Prevents overflow from the image going off screen */
      overflow: hidden;
      .cs-container {
        width: 100%;
        max-width: (1322/16em);
        margin: auto;
      }

      .cs-topper {
        text-align: center;
        margin-bottom: (16/16rem);
      }

      .cs-title {
        text-align: center;
        max-width: (621/16rem);
        margin-bottom: (40/16rem);
      }

      .cs-image-group {
        /* used rem so it doesn't scale with the font size of on parent */
        font-size: ~"min(1.1vw, 1em)";
        width: 100%;
        max-width: (1322/16em);
        margin: 0 auto (60/16rem);
        padding: 0;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        gap: (30/16em);
      }

      .cs-row {
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        align-items: center;
        gap: (30/16em);
      }

      .cs-picture {
        display: block;
        position: relative;
        img {
          width: 100%;
          height: 100%;
          object-fit: cover;
          position: absolute;
          top: 0;
          left: 0;
        }
      }

      .cs-row-1 {
        .cs-picture1 {
          width: (420/16em);
          height: (567/16em);
        }

        .cs-picture2 {
          width: (420/16em);
          height: (629/16em);
        }

        .cs-picture3 {
          width: (420/16em);
          height: (512/16em);
        }
      }

      .cs-row-2 {
        .cs-picture1 {
          width: (420/16em);
          height: (492/16em);
        }

        .cs-picture2 {
          width: (420/16em);
          height: (517/16em);
        }

        .cs-picture3 {
          width: (420/16em);
          height: (629/16em);
        }
      }

      .cs-row-3 {
        .cs-picture1 {
          width: (420/16em);
          height: (625/16em);
        }

        .cs-picture2 {
          width: (420/16em);
          height: (452/16em);
        }

        .cs-picture3 {
          width: (420/16em);
          height: (629/16em);
        }
      }
    }
  }

  /* Dark mode */
  @media only screen and (min-width: 0em) {
    body.dark-mode {
      #gallery {
        .cs-title {
          color: var(--bodyTextColorWhite);
        }
      }
    }
  }
</style>
