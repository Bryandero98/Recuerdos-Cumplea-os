---
// No utils nor props for this component
---

<section id="video-saludo">
	<div class="cs-container">
		<span class="cs-topper">Con mucho cariño</span>
		<h2 class="cs-title">Un saludo en video</h2>
		<p class="cs-text">También llegó este mensaje especial para ti, lleno de cariño y buenos deseos.</p>

		<div class="cs-video-wrapper">
			<video
				controls
				preload="metadata"
				playsinline
				class="cs-video"
			>
				<source src="/videos/saludo-tias-morelia.mp4" type="video/mp4" />
			</video>
		</div>
	</div>
</section>

<style lang="less">
	/* Mobile - 360px */
	@media only screen and (min-width: 0em) {
		#video-saludo {
			padding: var(--sectionPadding);
			text-align: center;

			.cs-container {
				width: 100%;
				max-width: (800/16rem);
				margin: auto;
			}

			.cs-topper {
				text-align: center;
				margin-bottom: (16/16rem);
			}

			.cs-title {
				text-align: center;
				max-width: (600/16rem);
				margin: 0 auto (16/16rem);
			}

			.cs-text {
				font-size: clamp(0.9375rem, 1.5vw, 1rem);
				line-height: 1.7em;
				text-align: center;
				max-width: (580/16rem);
				margin: 0 auto (40/16rem);
				color: var(--bodyTextColor);
			}

			.cs-video-wrapper {
				width: 100%;
				border-radius: (12/16rem);
				overflow: hidden;
				box-shadow: 0px 20px 40px rgba(0, 0, 0, 0.08);
			}

			.cs-video {
				display: block;
				width: 100%;
				height: auto;
			}
		}
	}

	/* Dark Mode */
	@media only screen and (min-width: 0em) {
		body.dark-mode {
			#video-saludo {
				.cs-text {
					color: var(--bodyTextColorWhite);
				}

				.cs-title {
					color: var(--bodyTextColorWhite);
				}

				.cs-video-wrapper {
					box-shadow: 0px 20px 40px rgba(0, 0, 0, 0.3);
				}
			}
		}
	}
</style>
